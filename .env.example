# =========================================================
# Polity Bros / Polity Games
# Variáveis de ambiente — TEMPLATE
# ---------------------------------------------------------
# Copie este arquivo para ".env" e preencha os valores reais:
#   cp .env.example .env
#
# NUNCA commite o .env real. Apenas este .example é versionado.
# =========================================================

# ---------------------------------------------------------
# Supabase — CLIENTE (exposto ao browser via Vite)
# Prefixo VITE_ é obrigatório para ficar acessível no front.
# A anon key é PÚBLICA por design (protegida por RLS).
# ---------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------
# Supabase — SERVIDOR (NUNCA expor ao browser!)
# Usada SOMENTE dentro das Edge Functions.
# Sem prefixo VITE_ para não vazar no bundle do client.
# ---------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only
SUPABASE_URL=https://your-project-ref.supabase.co

# ---------------------------------------------------------
# App / Ambiente
# ---------------------------------------------------------
NODE_ENV=development
VITE_APP_ENV=development

# ---------------------------------------------------------
# (Opcional) URLs de deploy / callbacks
# ---------------------------------------------------------
# VITE_SITE_URL=http://localhost:5173
