# =========================================================
# Polity Bros / Polity Games
# Git
# =========================================================

# ---------------------------------------------------------
# Dependencies
# ---------------------------------------------------------
node_modules/

# ---------------------------------------------------------
# Build outputs
# ---------------------------------------------------------
dist/
build/
coverage/
*.tsbuildinfo

# Build específico por app
/game/dist/
/web/dist/

# Vite
.vite/

# ---------------------------------------------------------
# Environment files
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# Raw assets (não vão para deploy)
# ---------------------------------------------------------
/assets-raw/*
!/assets-raw/.gitkeep

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------
# OS / system files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------
# Editors / IDE
# ---------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.tmp

# ---------------------------------------------------------
# Local test / misc
# ---------------------------------------------------------
.tmp/
temp/
tmp/

# ---------------------------------------------------------
# Supabase local / generated files
# ---------------------------------------------------------
/supabase/.temp/
/supabase/.branches/
/supabase/.cache/

# Deno local artifacts (Edge Functions)
deno.lock

# ---------------------------------------------------------
# Vercel
# ---------------------------------------------------------
.vercel/

# ---------------------------------------------------------
# Runtime / cache artifacts
# ---------------------------------------------------------
.cache/
.eslintcache

# ---------------------------------------------------------
# Optional: screenshots / recordings locais
# (descomente se começar a gerar isso localmente)
# ---------------------------------------------------------
# screenshots/
# recordings/
# *.mp4
# *.webm
# *.png

# ---------------------------------------------------------
# Keep tracked templates/docs/specs
# ---------------------------------------------------------
!.env.example
.vercel
.env*

# Playwright (T07E-03)
test-results/
playwright-report/
